@model IEnumerable<StudentModel>

@{
    ViewData["Title"] = "Student List";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Student Management</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Add New Student
    </a>
</div>

@if (TempData["msg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["msg"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Student List</h4>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Branch</th>
                        <th>Email</th>
                        <th>DOB</th>
                        <th>City</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.student_id</td>
                                <td>@item.studentname</td>
                                <td>@item.studentbranch</td>
                                <td>@item.student_email</td>
                                <td>@item.DOB</td>
                                <td>@item.city</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.student_id" class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.student_id" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-muted">No students found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
