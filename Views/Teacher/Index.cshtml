@model IEnumerable<mvc_btech.Models.TeacherModel>

@{
    ViewData["Title"] = "Teachers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Teacher Management</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Add New Teacher
    </a>
</div>

@if (TempData["msg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["msg"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Teacher List</h4>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Subject</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.teacher_id</td>
                                <td>@item.teacher_name</td>
                                <td>@item.subject</td>
                                <td>@item.email</td>
                                <td>@item.phone</td>
                                <td>
                                    <button class="btn btn-warning btn-sm">Edit</button>
                                    <button class="btn btn-danger btn-sm">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-muted">No teachers found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
