@model IEnumerable<mvc_btech.Models.CourseModel>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Course Management</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Course
    </a>
</div>

@if (TempData["msg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["msg"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Available Courses</h4>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover text-center">
                <thead class="table-light">
                    <tr>
                        <th>Course ID</th>
                        <th>Course Name</th>
                        <th>Duration (Months)</th>
                        <th>Fees (INR)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.course_id</td>
                                <td>@item.coursename</td>
                                <td>@item.duration</td>
                                <td>@item.fees.ToString("C2", new System.Globalization.CultureInfo("en-IN"))</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-muted">No courses available.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
