<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - School Management System</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            overflow-x: hidden;
        }

        .sidebar {
            height: 100vh;
            background-color: #1e293b;
        }

            .sidebar a {
                color: #cbd5e1;
                text-decoration: none;
                padding: 12px 20px;
                display: block;
                font-weight: 500;
            }

                .sidebar a:hover {
                    background-color: #334155;
                    color: white;
                }

        .content-area {
            padding: 25px;
        }

        footer {
            background-color: #f8f9fa;
            padding: 10px;
            text-align: center;
        }
    </style>
</head>
<body>

    <!-- 🔷 Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                🏫 School Management
            </a>

            <div class="ms-auto text-white fw-semibold">
                @* Welcome, Admin *@
                Welcome, @Context.Session.GetString("Name")
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">

            <!-- 🔷 Sidebar -->
            <div class="col-md-2 sidebar p-0">

                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a asp-controller="Student" asp-action="Create">
                    <i class="bi bi-people"></i> Students
                </a>

                <a asp-controller="Teacher" asp-action="Index">
                    <i class="bi bi-person-badge"></i> Teachers
                </a>

                <a asp-controller="Course" asp-action="Index">
                    <i class="bi bi-book"></i> Courses
                </a>

                <a asp-controller="Attendance" asp-action="Index">
                    <i class="bi bi-calendar-check"></i> Attendance
                </a>

                <a asp-controller="Fees" asp-action="Add">
                    <i class="bi bi-cash-coin"></i> Fees
                </a>

                <a asp-controller="Exam" asp-action="Index">
                    <i class="bi bi-file-earmark-text"></i> Exams
                </a>

                <a asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>

            </div>

            <!-- 🔷 Main Content -->
            <div class="col-md-10 content-area">
                @RenderBody()
            </div>

        </div>
    </div>

    <!-- 🔷 Footer -->
    <footer>
        © @DateTime.Now.Year School Management System | ASP.NET Core MVC
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>